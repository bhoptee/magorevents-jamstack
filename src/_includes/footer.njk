<footer class="main-footer">
  <div class="container">
    <div class="row" id="contact">

      <div class="col-lg-4 col-md-6">
        <a class="brand" href="/">
          <img src="/img/magor-events-400.png" class="nav-img-fluid" alt="{{ site.name }}">
        </a>
        <h6>{{ site.tagline }}</h6>
        <ul class="contact-info list-unstyled">
          <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        </ul>
        <ul class="social-icons list-inline">
          {% if site.facebook %}
          <li class="list-inline-item">
            <a href="{{ site.facebook }}" target="_blank" rel="noopener" title="Facebook">
              <i class="fab fa-facebook-f"></i>
            </a>
          </li>
          {% endif %}
          {% if site.twitter %}
          <li class="list-inline-item">
            <a href="{{ site.twitter }}" target="_blank" rel="noopener" title="Twitter / X">
              <i class="fab fa-x-twitter"></i>
            </a>
          </li>
          {% endif %}
          {% if site.instagram %}
          <li class="list-inline-item">
            <a href="{{ site.instagram }}" target="_blank" rel="noopener" title="Instagram">
              <i class="fab fa-instagram"></i>
            </a>
          </li>
          {% endif %}
        </ul>
      </div>

      <div class="col-lg-3">
        <h5>Our Events</h5>
        <ul class="links list-unstyled">
          <li><a href="/events#may-fayre">May Fayre</a></li>
          <li><a href="/events#frost-fayre">Frost Fayre</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5>About us</h5>
        <ul class="links list-unstyled">
          <li><a href="/about-us">What we do</a></li>
          <li><a href="/about-us#get-involved">Join us</a></li>
        </ul>
      </div>

    </div>
  </div>

  <div class="copyrights">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <p>&copy; <span id="copyright-year"></span> {{ site.name }}. All rights reserved.
          Magor Churchmen is part of the Magor Ministry Area registered charity number: {{ site.charity_reg }}.</p>
        </div>
      </div>
    </div>
  </div>
</footer>
<script>document.getElementById('copyright-year').textContent = new Date().getFullYear();</script>
